<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/exercise_card_bg"
    android:layout_marginBottom="12dp"
    android:elevation="4dp">

    <!-- Exercise Image -->
    <ImageView
        android:id="@+id/img_exercise"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_dummy_exercise"
        android:layout_gravity="center_vertical"
        android:contentDescription="Exercise Image" />

    <!-- Text Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_exercise_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jumping Jacks"
            android:textSize="18sp"
            android:textColor="#8A000000"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_exercise_sets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 sets x 15 reps"
            android:textSize="15sp"
            android:textColor="#8A000000"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_exercise_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 min"
            android:textSize="15sp"
            android:textColor="#8A000000"
            android:layout_marginTop="1dp"/>
    </LinearLayout>

    <!-- Start Button -->
    <Button
        android:id="@+id/btn_start_exercise"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Start"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/brand_primary"
        android:layout_gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:fontFamily="sans-serif-medium"
        android:elevation="2dp"/>
</LinearLayout>
