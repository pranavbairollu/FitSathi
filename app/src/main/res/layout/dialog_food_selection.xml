<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background">

    <TextView
        android:id="@+id/dialog_food_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Food"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"/>

    <!-- Suggestions list (visible only for typed search, hidden for barcode pre-selected) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dialog_suggestions_list"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        android:visibility="visible"/>

    <!-- Serving size -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Serving size (grams)"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/serving_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="100"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_input"/>

    <!-- Meal type selection -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Meal Type"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="16dp"/>

    <Spinner
        android:id="@+id/dialog_meal_type_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_input"/>

    <!-- Source text -->
    <TextView
        android:id="@+id/source_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Source: Unknown"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="8dp"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:weightSum="3">

        <Button
            android:id="@+id/btn_add_food"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add"
            android:textColor="@android:color/white"
            android:background="@drawable/button_ok"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_use_default"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Use Default"
            android:textColor="@android:color/white"
            android:background="@drawable/button_default"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_cancel_food"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="@android:color/white"
            android:background="@drawable/button_cancel"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
