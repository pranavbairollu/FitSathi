<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipToPadding="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="24dp" />

        <!-- Appearance Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/icon_dark_mode"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_dark_mode"
                    android:contentDescription="Dark Mode"
                    app:tint="?attr/colorPrimary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/dark_mode_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Dark Mode"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    app:layout_constraintStart_toEndOf="@id/icon_dark_mode"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/dark_mode_switch"
                    app:layout_constraintBottom_toTopOf="@id/dark_mode_subtitle"
                    app:layout_constraintVertical_chainStyle="packed" />

                <TextView
                    android:id="@+id/dark_mode_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Follow system settings"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/dark_mode_title"
                    app:layout_constraintStart_toStartOf="@id/dark_mode_title"
                    app:layout_constraintEnd_toEndOf="@id/dark_mode_title"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dark_mode_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Meal Reminders Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meal Reminders"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/row_breakfast" layout="@layout/settings_row_switch" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_lunch" layout="@layout/settings_row_switch" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_dinner" layout="@layout/settings_row_switch" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_snacks" layout="@layout/settings_row_switch" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- General Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="General"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/row_language" layout="@layout/settings_row_clickable" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_reset_data" layout="@layout/settings_row_clickable" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_about" layout="@layout/settings_row_clickable" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_privacy_policy" layout="@layout/settings_row_clickable" />
                <View style="@style/DividerApp" />
                <include android:id="@+id/row_help" layout="@layout/settings_row_clickable" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
