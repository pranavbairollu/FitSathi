<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface"
    android:clipToPadding="false"
    android:paddingBottom="24dp"
    tools:context=".fragments.ProfileFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

                <!-- Curved Header -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/header_background"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/guideline_top"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.LargeComponent" />

                <!-- Guideline -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.22" />

                <!-- Profile Picture -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/profile_pic_card"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="?attr/colorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/guideline_top"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/profile_pic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_profile"
                            tools:srcCompat="@tools:sample/avatars" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Edit Profile FAB -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/edit_profile_pic_fab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:fabSize="mini"
                    android:src="@drawable/ic_edit"
                    app:tint="@android:color/white"
                    app:backgroundTint="?attr/colorPrimary"
                    app:layout_constraintEnd_toEndOf="@id/profile_pic_card"
                    app:layout_constraintBottom_toBottomOf="@id/profile_pic_card"
                    android:layout_margin="6dp" />

                <!-- Name -->
                <TextView
                    android:id="@+id/profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintTop_toBottomOf="@id/profile_pic_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="Pranav Bairollu" />

                <!-- Email -->
                <TextView
                    android:id="@+id/profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    app:layout_constraintTop_toBottomOf="@id/profile_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="pranav.bairollu@example.com" />

                <!-- Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/info_card"
                    style="@style/CardSettingsApp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/profile_email"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="8dp">

                                <include android:id="@+id/age_info" layout="@layout/item_profile_info" />
                                <View style="@style/DividerApp" />
                                <include android:id="@+id/height_info" layout="@layout/item_profile_info" />
                                <View style="@style/DividerApp" />
                                <include android:id="@+id/weight_info" layout="@layout/item_profile_info" />
                                <View style="@style/DividerApp" />
                                <include android:id="@+id/gender_info" layout="@layout/item_profile_info" />
                                <View style="@style/DividerApp" />
                                <include android:id="@+id/activity_info" layout="@layout/item_profile_info" />
                        </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:id="@+id/action_buttons"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/info_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                        <!-- Edit Personal Details Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/edit_profile_button"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Edit Personal Details"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"
                            app:cornerRadius="24dp"
                            app:icon="@drawable/ic_edit"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        <!-- Share Progress Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/share_progress_button"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Share Weekly Progress"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"
                            app:cornerRadius="24dp"
                            app:icon="@drawable/ic_share"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:backgroundTint="?attr/colorPrimaryContainer"
                            app:iconTint="?attr/colorPrimary"
                            android:textColor="?attr/colorPrimary" />

                        <!-- Logout Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/logout_button"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Logout"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:cornerRadius="24dp"
                            app:backgroundTint="@color/error_light"
                            app:icon="@drawable/ic_logout"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp" />

                </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
