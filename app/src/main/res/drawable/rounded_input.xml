<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Use a concrete color for the background -->
    <solid android:color="@android:color/white"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Use a concrete color for the stroke -->
    <stroke
        android:width="1dp"
        android:color="@color/outline"/>

    <!-- Padding inside EditText -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>
</shape>
