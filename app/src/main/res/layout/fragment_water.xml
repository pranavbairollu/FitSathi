<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".fragments.WaterFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Decorative Background Shape -->
            <View
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:background="?attr/colorPrimary"
                android:layout_alignParentTop="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header -->
                <TextView
                    android:id="@+id/tv_water_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Water Intake"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stay hydrated to fuel your day!"
                    android:textSize="16sp"
                    android:layout_gravity="center_horizontal"
                    android:textColor="@android:color/white"
                    android:alpha="0.8"
                    android:layout_marginBottom="32dp"/>

                <!-- Main Display Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="24dp">

                        <ImageView
                            android:id="@+id/img_water_drop_main"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_water_drop"
                            app:tint="?attr/colorPrimary"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:id="@+id/tv_water_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="4 / 8"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Glasses Today"
                            android:textSize="18sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:layout_marginBottom="24dp"/>

                        <!-- Control Buttons -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_decrease_water"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:icon="@drawable/ic_remove"
                                app:iconSize="28dp"
                                app:iconTint="?android:attr/textColorPrimary"
                                app:strokeColor="?attr/colorPrimary"
                                app:cornerRadius="16dp" />

                            <!-- Invisible Spacer to push FAB to the center -->
                            <View
                                android:layout_width="100dp"
                                android:layout_height="0dp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- History Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Log"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginBottom="16dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_water_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_water_log"
                    tools:itemCount="3"/>

            </LinearLayout>
        </RelativeLayout>
    </ScrollView>

    <!-- Main action button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_increase_water"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="110dp"
        app:srcCompat="@drawable/ic_add"
        app:tint="@android:color/white"
        app:backgroundTint="?attr/colorPrimary"
        app:fabSize="normal"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
