<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set Your Daily Goal"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="20dp" />

    <!-- Card View Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        android:padding="20dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Switch between Default / Custom -->
            <RadioGroup
                android:id="@+id/rgGoalChoice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbDefault"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use Default Goal (10,000 steps)"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbCustom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Custom Goal" />
            </RadioGroup>

            <!-- Input for Custom Goal -->
            <EditText
                android:id="@+id/etCustomGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter your goal (steps)"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/rounded_input"
                android:layout_marginTop="16dp"
                android:enabled="false" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Save Button -->
    <Button
        android:id="@+id/btnSaveGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Goal"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:padding="14dp"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="10dp" />

</LinearLayout>
