<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Gradient background -->
    <gradient
        android:startColor="#FF6B6B"
        android:endColor="#FF4C4C"
        android:angle="45"/>

    <!-- Shadow/optional stroke -->
    <stroke
        android:width="1dp"
        android:color="#D32F2F"/>

    <!-- Optional padding inside the button -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp"/>
</shape>
